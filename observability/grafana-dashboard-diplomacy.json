{
  "dashboard": {
    "id": null,
    "uid": "powrush-diplomacy",
    "title": "Powrush-MMO | Diplomacy & War Priority Queue",
    "tags": ["powrush", "diplomacy", "war", "patsagi"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "panels": [
      {
        "type": "stat",
        "title": "High Priority Diplomacy Messages / sec",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(powrush_high_priority_messages[1m])",
            "legendFormat": "High Priority"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 20 }
              ]
            }
          }
        }
      },
      {
        "type": "stat",
        "title": "Normal Priority Diplomacy Messages / sec",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "rate(powrush_normal_priority_messages[1m])",
            "legendFormat": "Normal Priority"
          }
        ]
      },
      {
        "type": "stat",
        "title": "Total Diplomacy Messages / sec",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(powrush_high_priority_messages[1m]) + rate(powrush_normal_priority_messages[1m])",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "type": "stat",
        "title": "Connected Clients (last broadcast)",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "powrush_clients or vector(0)",
            "legendFormat": "Clients"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Diplomacy Message Rate (High vs Normal)",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "rate(powrush_high_priority_messages[1m])",
            "legendFormat": "High Priority"
          },
          {
            "expr": "rate(powrush_normal_priority_messages[1m])",
            "legendFormat": "Normal Priority"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Connected Clients During Diplomacy Broadcasts",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "powrush_clients",
            "legendFormat": "Clients"
          }
        ]
      },
      {
        "type": "table",
        "title": "Recent High Priority Diplomacy Events",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "increase(powrush_high_priority_messages[5m]) > 0",
            "legendFormat": "High Priority Events"
          }
        ]
      }
    ]
  }
}