# Powrush-MMO Sovereign Environment Configuration
# Copy to .env and fill values

# PostgreSQL (used by persistence layer)
POSTGRES_PASSWORD=change_this_to_a_strong_password

# === Divine Intelligence (Ra-Thor Priority) ===
# Primary path: Local Ra-Thor core (ra-thor-core crate from sibling Ra-Thor monorepo)
#   - Mercy gates, valence scoring, Divine Whispers, and PATSAGi guidance run fully locally.
#   - No external API calls required for core divine features or stand-alone operation.

# Optional bootstrap / augmentation only (temporary scaffolding):
#   GROK_API_KEY and XAI_API_KEY may be used in early development for high-quality
#   natural language generation while local hybrid inference matures.
#   These are NOT required. For fully sovereign v1.0+ releases, remove or leave empty.
#   The system is designed to run 100% offline using only Autonomicity Games proprietary Ra-Thor lattice.
GROK_API_KEY=
XAI_API_KEY=

# Game server tuning (optional overrides)
# POWRUSH_MAX_PLAYERS=256
# POWRUSH_TICK_RATE_MS=50
